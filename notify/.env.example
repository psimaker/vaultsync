# Copy this file to .env and adjust values, or run ./scripts/bootstrap.sh
SYNCTHING_API_URL=http://localhost:8384
SYNCTHING_API_KEY=replace-with-your-syncthing-api-key
RELAY_URL=https://relay.vaultsync.eu
DEBOUNCE_SECONDS=5
# Optional periodic wake-up poke for iPhone -> server catch-up. 0 disables it.
POKE_INTERVAL_MINUTES=0
# Optional experimental direct-upload endpoint for iPhone -> server markdown uploads.
# Set all three variables together or leave them all empty/disabled.
UPLOAD_LISTEN_ADDR=
UPLOAD_PORT_PUBLISH=127.0.0.1:8091:8091
UPLOAD_ROOT_DIR=/var/syncthing/obsidian
UPLOAD_AUTH_TOKEN=
# Optional comma-separated folder IDs. Leave empty to watch all folders.
WATCHED_FOLDERS=
