# Copy this file to .env and adjust values, or run ./scripts/bootstrap.sh.
#
# In most setups you can leave SYNCTHING_API_KEY and SYNCTHING_API_URL unset:
# the helper auto-detects them from Syncthing's config.xml (point SYNCTHING_CONFIG
# at it if it isn't in a standard location). There is no API key to copy.
#
# If you set SYNCTHING_API_KEY explicitly here, keep this .env at mode 0600
# (bootstrap.sh does this for you) — it then holds a secret.

# Required — the relay endpoint. Deliberately has no built-in default so the
# helper never sends traffic anywhere you didn't choose.
RELAY_URL=https://relay.vaultsync.eu

# Optional — auto-detected from config.xml when unset.
#SYNCTHING_API_URL=http://localhost:8384
#SYNCTHING_API_KEY=
# Optional — explicit path to Syncthing's config.xml (otherwise standard
# locations are probed, including the Docker images' config dirs).
#SYNCTHING_CONFIG=/var/syncthing/config/config.xml

DEBOUNCE_SECONDS=5
# Optional comma-separated folder IDs. Leave empty to watch all folders.
WATCHED_FOLDERS=
