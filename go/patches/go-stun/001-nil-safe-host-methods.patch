 // Family returns the family type of a host (IPv4 or IPv6).
 func (h *Host) Family() uint16 {
+	if h == nil {
+		return 0
+	}
 	return h.family
 }

 // IP returns the internet protocol address of the host.
 func (h *Host) IP() string {
+	if h == nil {
+		return ""
+	}
 	return h.ip
 }

